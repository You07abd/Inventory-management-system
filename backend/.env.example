# Local / demo configuration
DATABASE_URL=postgresql+psycopg2://inv_user:inv_pass@localhost:5433/drone_inventory
FRONTEND_ORIGIN=http://localhost:5173

# Auth — REQUIRED. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-only-insecure-change-me
SESSION_TTL_HOURS=12

# Environment: "development" (default) or "production".
# In production, docs are hidden and a strong SECRET_KEY is enforced.
ENV=development

# Cookie flags. Locally over http these must stay relaxed.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=            # leave blank for localhost

# Run Alembic migrations automatically on startup (single-instance only).
RUN_MIGRATIONS_ON_STARTUP=true
