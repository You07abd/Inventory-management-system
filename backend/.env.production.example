# Production configuration — set these as secrets in Coolify (never commit real values)
# Copy to .env.production and fill in the values from your Coolify PostgreSQL service.
DATABASE_URL=postgresql+psycopg2://<user>:<password>@<host>:<port>/<dbname>
FRONTEND_ORIGIN=https://aryx.dev

# Auth — REQUIRED. Generate a strong value:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# The app refuses to boot in production if this is unset or left at the dev default.
SECRET_KEY=<generate-a-strong-random-value>
SESSION_TTL_HOURS=12

# Seed bootstrap passwords used by seed.py when creating initial users.
# In production, the seeder must refuse to run with a non-zero exit if either
# value is missing, shorter than 12 chars, or otherwise considered weak.
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SEED_USER_PASSWORD=CHANGE_ME_STRONG_PASSWORD

ENV=production

# Cross-subdomain cookie (frontend on aryx.dev, API on api.aryx.dev are same-site).
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=.aryx.dev

# In multi-replica setups set this to false and run migrations as a deploy step.
RUN_MIGRATIONS_ON_STARTUP=true
